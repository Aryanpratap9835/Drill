#include <bits/stdc++.h>
using namespace std;
#define int long long
int binpow(int x,int n,int p){
    if(n==0)return 1;
    int temp=binpow(x,n/2,p);
    temp=(temp*temp)%p;
    if(n%2!=0){
        temp=(x*temp)%p;
    }
    return temp;
}
signed main() {
	// your code goes here
	int n;
	cin>>n;
	int mod=1e9+7;
	int ans=binpow(2,n,mod);
	cout<<ans<<"\n";
}
