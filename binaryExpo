
#include <bits/stdc++.h>
using namespace std;
#define int long long

int binpow(int a, int b, int p) {
    if (b == 0) return 1;
    int temp = binpow(a, b / 2, p);
    temp = (temp * temp) % p;
    if (b & 1) temp = (temp * a) % p;
    return temp;
}

signed main() {
    // Fast I/O
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int t;
    cin >> t;
    while (t--) {
        int a, b, c, p;
        cin >> a >> b >> c >> p;
        
        int exp = (b == 0 && c > 0);
        if (a % p == 0) {
            if (exp) {
                cout << 1 << "\n";
            } else {
                cout << 0 << "\n";
            }
            continue;
        }
        
        // Using Fermat's Little Theorem: generic tower power a^(b^c) % p
        int pow = binpow(b, c, p - 1);
        int ans = binpow(a, pow, p);
        cout << ans << "\n";
    }
    return 0;
}
